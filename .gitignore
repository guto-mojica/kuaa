# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
.Python
dist/
build/
.eggs/
.installed.cfg
MANIFEST

# ─── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/
.env/

# ─── uv ───────────────────────────────────────────────────────────────────────
# Lockfile is now committed. uv.lock is tracked — do not add it back to .gitignore.

# ─── Dados e acervo — NUNCA commitar vídeos ou frames ─────────────────────────
# Os dados são locais em cada instituição e podem ter GBs ou TBs.
# Somente os metadados gerados (JSON) são versionados, se desejado.
data/raw/
data/frames/
data/embeddings/
data/library/
data/_test*

# Metadados gerados — opcional versionar, mas costumam ser grandes.
# Para versionar metadados de um filme específico, remova a linha abaixo
# e use: git add data/metadata/jeca_tatu/
data/metadata/

# Public-demo runtime artifacts are downloaded/generated, not committed.
# Keep data/demo/README.md and data/demo/manifest.json tracked.
data/demo/runtime/

# Evaluation reports are generated runtime output; source query YAML is tracked.
data/eval/reports/

# Per-run eval output (candidate slates, grades JSONL, frozen tarballs) are
# runtime artefacts — only the committed seed YAMLs + README belong in git.
# See docs/EVAL_PROTOCOL.md §5.
# Patterns cover both directory layout (data/eval/<run_id>/) and the legacy
# single-file layout that `cinemateca eval seed` writes (data/eval/<run_id>.queries.json
# + the matching <run_id>.jsonl grade log).
data/eval/*-run-*/
data/eval/*-run-*.queries.json
data/eval/*-run-*.jsonl
data/eval/*.frozen-*.tar.gz

# ─── Modelos ──────────────────────────────────────────────────────────────────
# Modelos são baixados automaticamente na primeira execução.
# Não devem ser commitados (são GBs e têm suas próprias licenças).
/models/
# src/cinemateca/models/ is Python source code — must be tracked.
!src/cinemateca/models/
*.pt
*.pth
*.onnx
*.bin
*.safetensors
*.ckpt
*.gguf

# ─── Outputs ──────────────────────────────────────────────────────────────────
outputs/
logs/

# ─── Configuração local — NUNCA commitar ──────────────────────────────────────
# config/local.yaml contém caminhos e possivelmente chaves de API específicas
# de cada máquina. Cada instalação tem o seu.
config/local.yaml
config/*.local.yaml
.env
*.env
.env.*
!.env.example

# ─── IDEs e editores ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Jupyter ──────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ─── Pytest e cobertura ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Mypy e type checkers ─────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ─── Ruff ─────────────────────────────────────────────────────────────────────
.ruff_cache/
.import_linter_cache/

# ─── Uploads temporários do Streamlit (legacy) ────────────────────────────────
# Streamlit salva uploads em /tmp — não commitar se redirecionar para o projeto.
data/raw/_query_*
data/raw/_upload_*

# ─── Agent / Claude Code workspace ────────────────────────────────────────────
# Nothing under .claude/ is tracked (worktrees, local settings, transcripts).
.claude/

# ─── Private working docs ─────────────────────────────────────────────────────
# Internal planning notes, design drafts, and per-run working checklists. Kept
# locally for the author; not part of the public portfolio surface.
.notes/
PORTFOLIO_FIXES.md
FEATURE_PROOF.md

