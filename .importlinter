[importlinter]
root_packages =
    cinemateca
    api

[importlinter:contract:no-core-imports-api]
# When a P1 extraction needs a helper that still lives in `api/services/*`
# (most commonly catalog.{load_tag_index, keyframe_url, to_smpte}, or
# film_context.FilmContext), implementers should PREFER inlining a small
# helper over adding a carve-out — see cinemateca.search.bm25._load_tag_index
# for the pattern. If inlining is impractical (helper is large, or used by
# many extracted modules), add an `ignore_imports` entry below with a one-line
# justification in the commit message. P2 will move those helpers under
# `cinemateca.library` and the carve-outs delete.
name=cinemateca core must not import api/
type=forbidden
source_modules=
    cinemateca
forbidden_modules=
    api

[importlinter:contract:routes-not-direct-core]
# Provisional — relaxed during P1 because routes currently call FilmContext
# directly AND import cinemateca.retrieval.hybrid for DEFAULT_RRF_K /
# resolve_weights. ``allow_indirect_imports = True`` so transitive chains
# routed through ``api.services.*`` are NOT flagged; only direct imports
# from ``api.routes.search`` into core packages would fail this contract.
# ``ignore_imports`` carves out the one direct chain that exists today and
# will be removed in Tasks 14/15 when the route stops calling helpers in
# ``cinemateca.retrieval`` directly. Task 16 tightens by deleting the
# ignore entry.
name=routes use services, not core directly
type=forbidden
source_modules=
    api.routes.search
forbidden_modules=
    cinemateca.search
    cinemateca.retrieval
    cinemateca.embeddings
allow_indirect_imports=True
ignore_imports=
    api.routes.search -> cinemateca.retrieval.hybrid
