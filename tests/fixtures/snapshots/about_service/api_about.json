\n                            <div class=\"org\">\n                                <span class=\"by\">Vikhyat</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/vikhyat/moondream\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">Apache-2</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico green\">Y</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    ultralytics/yolov8m<span class=\"ver\">v8m</span>\n                                </div>\n                                <div class=\"role\"><b>Object detection</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">Ultralytics</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/ultralytics/ultralytics\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">AGPL-3</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico orange\">F</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    facenet/mtcnn\n                                </div>\n                                <div class=\"role\"><b>Face detection</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">facenet-pytorch</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/timesler/facenet-pytorch\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">MIT</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico pink\">A</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    laion/larger_clap_general<span class=\"ver\">general</span>\n                                </div>\n                                <div class=\"role\"><b>Audio embedding</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">LAION</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/LAION-AI/CLAP\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">MIT</span>\n                        </div>\n                    \n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Stack</span>\n                    <span class=\"ct\">9</span>\n                </div>\n                <div class=\"ab-stack\">\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>Python 3.10+\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>FastAPI\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>Jinja2\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>HTMX 1.9\n                        </span>\n                    \n                        <span class=\"ab-stack-pill yellow\">\n                            <span class=\"dot\"></span>PyTorch\n                        </span>\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>NumPy\n                        </span>\n                    \n                        <span class=\"ab-stack-pill pink\">\n                            <span class=\"dot\"></span>FFmpeg\n                        </span>\n                    \n                        <span class=\"ab-stack-pill green\">\n                            <span class=\"dot\"></span>PySceneDetect\n                        </span>\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>Babel · PT-BR / EN\n                        </span>\n                    \n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Credits</span>\n                </div>\n                <div class=\"ab-credits\">\n                    \n                        <span class=\"k\">Concept</span>\n                        <span class=\"v\">Cinemateca Mojica · Curatorial team</span>\n                    \n                        <span class=\"k\">Engineering</span>\n                        <span class=\"v\">Rafael Perez</span>\n                    \n                        <span class=\"k\">AI integration</span>\n                        <span class=\"v dim\">moondream, openai, ultralytics, laion (model authors)</span>\n                    \n                        <span class=\"k\">Funding</span>\n                        <span class=\"v dim\">—</span>\n                    \n                        <span class=\"k\">Year</span>\n                        <span class=\"v\">2026</span>\n                    \n                </div>\n            </div>\n\n            \n            <div class=\"ab-foot\">\n                <div class=\"l\"></div>\n                <div class=\"r\">\n                    <button class=\"ghost-btn\" type=\"button\"\n                            @click=\"close()\">\n                        Close\n                    </button>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</div>"
