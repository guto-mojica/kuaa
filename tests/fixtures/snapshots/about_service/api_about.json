"\n\n<div class=\"ab-app\" id=\"about\"\n     role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"about-title\"\n     x-data=\"{ close() { document.getElementById('modal-container').innerHTML = '' } }\"\n     @keydown.escape.window=\"close()\">\n    \n    <div class=\"ab-bg\">\n        <div class=\"layer\">\n            \n        </div>\n        <div class=\"vignette\"></div>\n        <div class=\"grain\"></div>\n    </div>\n\n    <div class=\"ab-overlay\" @click.self=\"close()\">\n        <div class=\"ab-modal\" role=\"document\">\n\n            \n            <div class=\"ab-head\">\n                <button class=\"close\" type=\"button\"\n                        @click=\"close()\"\n                        aria-label=\"Close\"\n                        title=\"Close · Esc\">×</button>\n\n                <div class=\"ab-mark-row\">\n                    <div class=\"mk\"><svg width=\"26\" height=\"26\" viewBox=\"0 0 22 22\" fill=\"none\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"0.5\" y=\"2.5\" width=\"21\" height=\"17\" stroke=\"currentColor\" stroke-width=\"1.2\" rx=\"3\"/><rect x=\"2.5\" y=\"4.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"2.5\" y=\"9.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"2.5\" y=\"14.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"17\" y=\"4.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"17\" y=\"9.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"17\" y=\"14.5\" width=\"2.5\" height=\"2.5\" rx=\"0.7\" fill=\"currentColor\"/><rect x=\"7\" y=\"6\" width=\"8\" height=\"10\" rx=\"1.5\" fill=\"var(--c-accent)\"/></svg></div>\n                    <div></div>\n                    <span class=\"runtag\">\n                        <span class=\"dot\"></span>\n                        v0.8.0rc1 stable\n                    </span>\n                </div>\n\n                <h1 id=\"about-title\">Cinemateca Mojica</h1>\n\n                <div class=\"vrow\">\n                    <span class=\"pill\">Digital archive</span>\n                    <span class=\"dot\">·</span>\n                    <span><span class=\"v\">v0.8.0rc1</span></span>\n                    <span class=\"dot\">·</span>\n                    <span class=\"pill lic\">MIT</span>\n                    \n                    <span class=\"dot\">·</span>\n                    <span>YYYY-MM-DD</span>\n                </div>\n\n                <p>\n                    Internal cataloguing and semantic search system for the Cinemateca Mojica archive.\n                    Indexes scenes, descriptions, visual and audio embeddings to support curation, programming and research.\n                    <b class=\"ac\">100% local</b> —\n                    no external service dependency, no outbound traffic at runtime.\n                </p>\n            </div>\n\n            \n            <div class=\"ab-body\">\n\n                \n                <div class=\"ab-stats\">\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">00</span>\n                        <span class=\"k\">indexed films</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">0</span>\n                        <span class=\"k\">detected scenes</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">—</span>\n                        <span class=\"k\">catalogued runtime</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">—</span>\n                        <span class=\"k\">time range</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Models</span>\n                    <span class=\"ct\">5</span>\n                </d