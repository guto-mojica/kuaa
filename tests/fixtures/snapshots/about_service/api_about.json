"\n\n<div class=\"ab-app\" id=\"about\"\n     role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"about-title\"\n     data-focus-trap\n     x-data=\"{ close() { document.getElementById('modal-container').innerHTML = '' } }\"\n     @keydown.escape.window=\"close()\">\n    \n    <div class=\"ab-bg\">\n        <div class=\"layer\">\n            \n        </div>\n        <div class=\"vignette\"></div>\n        <div class=\"grain\"></div>\n    </div>\n\n    <div class=\"ab-overlay\" @click.self=\"close()\">\n        <div class=\"ab-modal\" role=\"document\">\n\n            \n            <div class=\"ab-head\">\n                <button class=\"close\" type=\"button\"\n                        @click=\"close()\"\n                        aria-label=\"Close\"\n                        title=\"Close · Esc\">×</button>\n\n                <div class=\"ab-mark-row\">\n                    <div class=\"mk\"><img src=\"/static/img/kuaa-mark.svg\" width=\"64\" height=\"64\" alt=\"KUAA\" aria-hidden=\"true\"></div>\n                    <div></div>\n                    <span class=\"runtag\">\n                        <span class=\"dot\"></span>\n                        v0.8.0rc1 stable\n                    </span>\n                </div>\n\n                <h1 id=\"about-title\">KUAA</h1>\n\n                <div class=\"vrow\">\n                    <span class=\"pill\">Digital archive</span>\n                    <span class=\"dot\">·</span>\n                    <span><span class=\"v\">v0.8.0rc1</span></span>\n                    <span class=\"dot\">·</span>\n                    <span class=\"pill lic\">MIT</span>\n                    \n                    <span class=\"dot\">·</span>\n                    <span>YYYY-MM-DD</span>\n                </div>\n\n                <p>\n                    Knowledge from unstructured audiovisual archives. Cataloguing and semantic search for film archives.\n                    Indexes scenes, descriptions, visual embeddings to support curation, programming and research.\n                    <b class=\"ac\">100% local</b> —\n                    no external service dependency, no outbound traffic at runtime.\n                </p>\n            </div>\n\n            \n            <div class=\"ab-body\">\n\n                \n                <div class=\"ab-stats\">\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">00</span>\n                        <span class=\"k\">indexed films</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">0</span>\n                        <span class=\"k\">detected scenes</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">—</span>\n                        <span class=\"k\">catalogued runtime</span>\n                    </div>\n                    <div class=\"ab-stat\">\n                        <span class=\"n\">—</span>\n                        <span class=\"k\">time range</span>\n                    </div>\n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Models</span>\n                    <span class=\"ct\">4</span>\n                </div>\n                <div class=\"ab-models\">\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico\">C</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    openai/clip-vit-large-patch14<span class=\"ver\">L/14</span>\n                                </div>\n                                <div class=\"role\"><b>Visual embedding</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">OpenAI</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/openai/CLIP\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">MIT</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico yellow\">M</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    vikhyatk/moondream2<span class=\"ver\">v2</span>\n                                </div>\n                                <div class=\"role\"><b>Scene description</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">Vikhyat</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/vikhyat/moondream\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">Apache-2</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico green\">Y</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    ultralytics/yolov8m<span class=\"ver\">v8m</span>\n                                </div>\n                                <div class=\"role\"><b>Object detection</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">Ultralytics</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/ultralytics/ultralytics\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">AGPL-3</span>\n                        </div>\n                    \n                        <div class=\"ab-model\">\n                            <div class=\"ico orange\">F</div>\n                            <div class=\"info\">\n                                <div class=\"name\">\n                                    facenet/mtcnn\n                                </div>\n                                <div class=\"role\"><b>Face detection</b></div>\n                            </div>\n                            <div class=\"org\">\n                                <span class=\"by\">facenet-pytorch</span>\n                                \n                                    <a class=\"repo\" href=\"https://github.com/timesler/facenet-pytorch\"\n                                       target=\"_blank\" rel=\"noopener\">\n                                        <span class=\"ab-ghico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M10 13a5 5 0 0 0 7.5.5l3-3a5 5 0 0 0-7-7L11.6 5\"/><path d=\"M14 11a5 5 0 0 0-7.5-.5l-3 3a5 5 0 0 0 7 7l1.8-1.8\"/></svg></span>\n                                        repo\n                                    </a>\n                                \n                            </div>\n                            <span class=\"lic\">MIT</span>\n                        </div>\n                    \n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Stack</span>\n                    <span class=\"ct\">9</span>\n                </div>\n                <div class=\"ab-stack\">\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>Python 3.10+\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>FastAPI\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>Jinja2\n                        </span>\n                    \n                        <span class=\"ab-stack-pill ac\">\n                            <span class=\"dot\"></span>HTMX 1.9\n                        </span>\n                    \n                        <span class=\"ab-stack-pill yellow\">\n                            <span class=\"dot\"></span>PyTorch\n                        </span>\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>NumPy\n                        </span>\n                    \n                        <span class=\"ab-stack-pill pink\">\n                            <span class=\"dot\"></span>FFmpeg\n                        </span>\n                    \n                        <span class=\"ab-stack-pill green\">\n                            <span class=\"dot\"></span>PySceneDetect\n                        </span>\n                    \n                        <span class=\"ab-stack-pill\">\n                            <span class=\"dot\"></span>Babel · PT-BR / EN\n                        </span>\n                    \n                </div>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Keyboard shortcuts</span>\n                </div>\n                <dl class=\"ab-keys\" aria-label=\"Keyboard shortcuts\">\n                    \n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Search</dt>\n                            <dd>\n                                <kbd>1</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Scenes</dt>\n                            <dd>\n                                <kbd>2</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Annotate</dt>\n                            <dd>\n                                <kbd>3</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Visual rhymes</dt>\n                            <dd>\n                                <kbd>4</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Processing</dt>\n                            <dd>\n                                <kbd>5</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>Command palette</dt>\n                            <dd>\n                                <kbd>⌘</kbd><span class=\"plus\">+</span><kbd>K</kbd>\n                            </dd>\n                        </div>\n                    \n                        <div class=\"ab-key-row\">\n                            <dt>This help</dt>\n                            <dd>\n                                <kbd>?</kbd>\n                            </dd>\n                        </div>\n                    \n                </dl>\n\n                \n                <div class=\"ab-sect\">\n                    <span>Credits</span>\n                </div>\n                <div class=\"ab-credits\">\n                    \n                        <span class=\"k\">Concept</span>\n                        <span class=\"v\">KUAA · Curatorial team</span>\n                    \n                        <span class=\"k\">Engineering</span>\n                        <span class=\"v\">Augusto mojica Santos</span>\n                    \n                        <span class=\"k\">AI integration</span>\n                        <span class=\"v dim\">moondream, openai, ultralytics (model authors)</