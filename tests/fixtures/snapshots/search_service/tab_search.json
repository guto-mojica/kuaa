"\n\n\n<div class=\"tab-panel\">\n\n\n<section class=\"b-cp\"\n         x-data=\"{\n           mode: 'text',\n           \n           hits: 0,\n           filmsHit: 0,\n           searched: false,\n           recountResults() {\n             const grid = this.$refs.searchResults;\n             if (!grid) return;\n             const cards = grid.querySelectorAll('.b-card');\n             this.hits = cards.length;\n             const slugs = new Set();\n             cards.forEach((c) => {\n               const s = c.getAttribute('data-film-slug');\n               if (s) slugs.add(s);\n             });\n             this.filmsHit = slugs.size;\n             if (cards.length) this.searched = true;\n           },\n           clearResults() {\n             \n             const grid = this.$refs.searchResults;\n             if (grid) grid.innerHTML = '';\n             this.hits = 0;\n             this.filmsHit = 0;\n             this.searched = false;\n           },\n           refreshSearch() {\n             this.$nextTick(() => {\n               const input = this.$refs.searchInput;\n               if (input && input.value.trim().length >= 2 && window.htmx) {\n                 window.htmx.trigger('#search-text-form', 'submit');\n               }\n             });\n           },\n           \n           clearQueryError() {\n             const slot = document.getElementById('search-query-error');\n             if (slot) { slot.textContent = ''; slot.classList.remove('is-error'); }\n             const input = this.$refs.searchInput;\n             if (input) input.setAttribute('aria-invalid', 'false');\n           },\n           \n           syncQueryError() {\n             const slot = document.getElementById('search-query-error');\n             const input = this.$refs.searchInput;\n             if (!input) return;\n             const invalid = !!(slot && slot.classList.contains('is-error'));\n             input.setAttribute('aria-invalid', invalid ? 'true' : 'false');\n           }\n         }\"\n         x-init=\"recountResults()\"\n         @htmx:after-swap.window=\"if ($event.target && $event.target.id === 'search-results') { recountResults(); syncQueryError(); }\"\n         @htmx:oob-after-swap.window=\"if ($event.detail && $event.detail.target && $event.detail.target.id === 'search-query-error') syncQueryError()\">\n\n  \n  <div class=\"search-wrap\">\n    \n    <form id=\"search-text-form\"\n          class=\"qbar\"\n          hx-get=\"/api/search\"\n          hx-trigger=\"submit\"\n          hx-target=\"#search-results\"\n          hx-indicator=\"#search-skeleton\"\n          hx-include=\"#search-text-form, #search-tag-panel\"\n          hx-sync=\"this:replace\"\n          hx-push-url=\"true\">\n      \n      \n\n      \n      <input type=\"hidden\" name=\"retriever\" :value=\"$store.buscarRetrieval.mode\">\n      <input type=\"hidden\" name=\"sem_w\"     :value=\"$store.buscarRetrieval.sem_w\">\n      <input type=\"hidden\" name=\"bm25_w\"    :value=\"(1 - Number($store.buscarRetrieval.sem_w)).toFixed(2)\">\n      <input type=\"hidden\" name=\"top_k\"     :value=\"$store.buscarRetrieval.top_k\">\n      \n      <input type=\"hidden\" name=\"modality\" :value=\"$store.buscarRetrieval.modality\">\n      \n      <input type=\"hidden\" name=\"w\" :value=\"$store.buscarRetrieval.fusion_w\">\n      \n      <input type=\"hidden\" name=\"reranker_enabled\" :value=\"$store.buscarRetrieval.rerank_enabled ? 'true' : 'false'\">\n\n      <label class=\"qinput\" for=\"search-input\">\n        <span class=\"ico\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></span>\n        <input id=\"search-input\"\n               type=\"search\"\n               name=\"q\"\n               x-ref=\"searchInput\"\n               autocomplete=\"off\"\n               value=\"\"\n               aria-invalid=\"false\"\n               aria-describedby=\"search-query-error\"\n               placeholder=\"Search the library — describe a scene, paste an image…\"\n               hx-get=\"/api/search\"\n               hx-trigger=\"keyup changed delay:500ms\"\n               hx-target=\"#search-results\"\n               hx-indicator=\"#search-skeleton\"\n               hx-include=\"#search-text-form, #search-tag-panel\"\n               hx-sync=\"closest form:replace\"\n               @keydown=\"clearQueryError()\">\n        <span class=\"kbd\">⌘K</span>\n      </label>\n      \n      \n        \n\n\n\n  \n\n<span id=\"search-query-error\"\n      class=\"field-error\"\n      role=\"alert\"\n      aria-live=\"assertive\"\n      data-field-error\n      ></span>\n      \n      <button type=\"submit\" class=\"fx-btn primary\">\n        Search <span class=\"kbd\">⏎</span>\n      </button>\n    </form>\n\n    \n    <div class=\"modes\" role=\"tablist\" aria-label=\"Input type\" @change=\"refreshSearch()\">\n      \n      <button type=\"button\"\n              class=\"chip\"\n              :class=\"{ on: mode === 'text' }\"\n              data-mode=\"text\"\n              role=\"tab\"\n              :aria-selected=\"mode === 'text' ? 'true' : 'false'\"\n              @click=\"mode = 'text'; $store.buscarRetrieval.modality = 'text'; clearResults(); refreshSearch()\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></span>\n        Text\n      </button>\n      <button type=\"button\"\n              class=\"chip\"\n              :class=\"{ on: mode === 'image' }\"\n              data-mode=\"image\"\n              role=\"tab\"\n              :aria-selected=\"mode === 'image' ? 'true' : 'false'\"\n              \n              @click=\"mode = 'image'; clearResults()\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"/><polyline points=\"21 15 16 10 5 21\"/></svg></span>\n        Image\n      </button>\n      <button type=\"button\"\n              class=\"chip\"\n              :class=\"{ on: mode === 'audio' }\"\n              data-mode=\"audio\"\n              role=\"tab\"\n              :aria-selected=\"mode === 'audio' ? 'true' : 'false'\"\n              \n              @click=\"mode = 'audio'; $store.buscarRetrieval.modality = 'audio'; clearResults(); refreshSearch()\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M2 12h2l3-9 4 18 3-12 2 6h6\"/></svg></span>\n        Audio\n      </button>\n      <button type=\"button\"\n              class=\"chip\"\n              :class=\"{ on: mode === 'multimodal' }\"\n              data-mode=\"multimodal\"\n              role=\"tab\"\n              :aria-selected=\"mode === 'multimodal' ? 'true' : 'false'\"\n              \n              @click=\"mode = 'multimodal'; $store.buscarRetrieval.modality = 'fusion'; clearResults(); refreshSearch()\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><circle cx=\"6\" cy=\"6\" r=\"3\"/><circle cx=\"18\" cy=\"6\" r=\"3\"/><circle cx=\"6\" cy=\"18\" r=\"3\"/><circle cx=\"18\" cy=\"18\" r=\"3\"/><path d=\"M9 6h6M9 18h6M6 9v6M18 9v6\"/></svg></span>\n        Fusion\n      </button>\n\n      <span class=\"div-v\" aria-hidden=\"true\"></span>\n\n      \n\n      \n      <div class=\"knob knob-popover\" x-data=\"{ open: false }\">\n        <button type=\"button\"\n                class=\"knob-toggle\"\n                @click=\"open = !open\"\n                :aria-expanded=\"open ? 'true' : 'false'\"\n                aria-haspopup=\"dialog\">\n          <span class=\"k\" x-text=\"({ clip: 'CLIP', bm25: 'BM25', hybrid: 'Hybrid' })[$store.buscarRetrieval.mode]\"></span>\n          \n          <span class=\"v acc\" x-text=\"(\n            { clip: \"CLIP only\",\n              bm25: \"BM25 only\",\n              hybrid: 'sem ' + Number($store.buscarRetrieval.sem_w).toFixed(2) +\n                      ' bm25 ' + (1 - Number($store.buscarRetrieval.sem_w)).toFixed(2)\n            })[$store.buscarRetrieval.mode]\n          \"></span>\n        </button>\n        <div class=\"popover\"\n             x-show=\"open\"\n             x-cloak\n             @click.outside=\"open = false\"\n             role=\"dialog\"\n             aria-label=\"Retrieval mode\">\n          <h3>Retrieval mode</h3>\n          <label class=\"radio\">\n            <input type=\"radio\" value=\"hybrid\" x-model=\"$store.buscarRetrieval.mode\">\n            Hybrid\n          </label>\n          <label class=\"radio\">\n            <input type=\"radio\" value=\"clip\" x-model=\"$store.buscarRetrieval.mode\">\n            CLIP only\n          </label>\n          <label class=\"radio\">\n            <input type=\"radio\" value=\"bm25\" x-model=\"$store.buscarRetrieval.mode\">\n            BM25 only\n          </label>\n          <div class=\"slider-row\" x-show=\"$store.buscarRetrieval.mode === 'hybrid'\">\n            <label for=\"sem-w-slider\">\n              Semantic weight ↔ Lexical weight\n            </label>\n            <input type=\"range\"\n                   id=\"sem-w-slider\"\n                   min=\"0\" max=\"1\" step=\"0.05\"\n                   x-model.number=\"$store.buscarRetrieval.sem_w\">\n            <span class=\"slider-readout\">\n              sem <span x-text=\"Number($store.buscarRetrieval.sem_w).toFixed(2)\"></span>\n              · bm25 <span x-text=\"(1 - Number($store.buscarRetrieval.sem_w)).toFixed(2)\"></span>\n            </span>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"knob knob-popover\" x-data=\"{ open: false }\">\n        <button type=\"button\"\n                class=\"knob-toggle\"\n                @click=\"open = !open\"\n                :aria-expanded=\"open ? 'true' : 'false'\"\n                aria-haspopup=\"dialog\">\n          <span class=\"k\">k</span>\n          <span class=\"v\" x-text=\"$store.buscarRetrieval.top_k\"></span>\n        </button>\n        <div class=\"popover\"\n             x-show=\"open\"\n             x-cloak\n             @click.outside=\"open = false\"\n             role=\"dialog\"\n             aria-label=\"Results per query\">\n          <h3>Results per query</h3>\n          <div class=\"stepper\">\n            \n            <label class=\"radio\">\n              <input type=\"radio\" value=\"3\" x-model.number=\"$store.buscarRetrieval.top_k\">\n              3\n            </label>\n            \n            <label class=\"radio\">\n              <input type=\"radio\" value=\"6\" x-model.number=\"$store.buscarRetrieval.top_k\">\n              6\n            </label>\n            \n            <label class=\"radio\">\n              <input type=\"radio\" value=\"9\" x-model.number=\"$store.buscarRetrieval.top_k\">\n              9\n            </label>\n            \n            <label class=\"radio\">\n              <input type=\"radio\" value=\"12\" x-model.number=\"$store.buscarRetrieval.top_k\">\n              12\n            </label>\n            \n            <label class=\"radio\">\n              <input type=\"radio\" value=\"18\" x-model.number=\"$store.buscarRetrieval.top_k\">\n              18\n            </label>\n            \n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"knob knob-popover\"\n           x-data=\"{ open: false }\"\n           x-show=\"mode === 'text'\"\n           x-cloak>\n        <button type=\"button\"\n                class=\"knob-toggle\"\n                @click=\"open = !open\"\n                :aria-expanded=\"open ? 'true' : 'false'\"\n                aria-haspopup=\"dialog\">\n          <span class=\"k\">Rerank</span>\n          <span class=\"v\"\n                :class=\"{ acc: $store.buscarRetrieval.rerank_enabled }\"\n                x-text=\"$store.buscarRetrieval.rerank_enabled ? 'on' : 'off'\"></span>\n        </button>\n        <div class=\"popover\"\n             x-show=\"open\"\n             x-cloak\n             @click.outside=\"open = false\"\n             role=\"dialog\"\n             aria-label=\"Rerank\">\n          <h3>Rerank</h3>\n          <label class=\"radio\">\n            <input type=\"checkbox\" x-model=\"$store.buscarRetrieval.rerank_enabled\">\n            Cross-encoder rerank\n          </label>\n        </div>\n      </div>\n\n      \n      <div class=\"knob knob-popover\"\n           x-data=\"{ open: false }\"\n           x-show=\"mode === 'multimodal'\"\n           x-cloak>\n        <button type=\"button\"\n                class=\"knob-toggle\"\n                @click=\"open = !open\"\n                :aria-expanded=\"open ? 'true' : 'false'\"\n                aria-haspopup=\"dialog\">\n          <span class=\"k\">Fusion</span>\n          <span class=\"v acc\"\n                x-text=\"'visual ' + Number($store.buscarRetrieval.fusion_w).toFixed(2) +\n                        ' · audio ' + (1 - Number($store.buscarRetrieval.fusion_w)).toFixed(2)\"></span>\n        </button>\n        <div class=\"popover\"\n             x-show=\"open\"\n             x-cloak\n             @click.outside=\"open = false\"\n             role=\"dialog\"\n             aria-label=\"Visual ↔ Audio weight\">\n          <h3>Visual ↔ Audio weight</h3>\n          <div class=\"slider-row\">\n            <label for=\"fusion-w-slider\">\n              Visual weight ↔ Audio weight\n            </label>\n            <input type=\"range\"\n                   id=\"fusion-w-slider\"\n                   min=\"0\" max=\"1\" step=\"0.05\"\n                   x-model.number=\"$store.buscarRetrieval.fusion_w\">\n            <span class=\"slider-readout\">\n              visual <span x-text=\"Number($store.buscarRetrieval.fusion_w).toFixed(2)\"></span>\n              · audio <span x-text=\"(1 - Number($store.buscarRetrieval.fusion_w)).toFixed(2)\"></span>\n            </span>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"caption\">\n    \n    <div class=\"left\">\n      \n      <template x-if=\"searched && hits > 0\">\n        <span class=\"ttl\">\n          <b x-text=\"hits\"></b> results\n        </span>\n      </template>\n      <template x-if=\"searched && hits > 0\">\n        <span class=\"meta\">\n          <span x-show=\"filmsHit > 0\">· <b x-text=\"filmsHit\"></b> films</span>\n        </span>\n      </template>\n      \n      <template x-if=\"searched && hits === 0\">\n        <span class=\"ttl\">No results.</span>\n      </template>\n      \n      <template x-if=\"!searched && mode !== 'image'\">\n        <span class=\"ttl\">Type a query to search</span>\n      </template>\n    </div>\n    \n    <div class=\"right\" role=\"tablist\" aria-label=\"Result layout\">\n      <button type=\"button\"\n              class=\"seg\"\n              :class=\"{ on: $store.buscarView.mode === 'grid' }\"\n              data-view=\"grid\"\n              :aria-pressed=\"$store.buscarView.mode === 'grid' ? 'true' : 'false'\"\n              @click=\"$store.buscarView.mode = 'grid'\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\" rx=\"1\"/></svg> Grid\n      </button>\n      <button type=\"button\"\n              class=\"seg\"\n              :class=\"{ on: $store.buscarView.mode === 'list' }\"\n              data-view=\"list\"\n              :aria-pressed=\"$store.buscarView.mode === 'list' ? 'true' : 'false'\"\n              @click=\"$store.buscarView.mode = 'list'\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M3 6h18M6 12h12M10 18h4\"/></svg> List\n      </button>\n      <button type=\"button\"\n              class=\"seg\"\n              :class=\"{ on: $store.buscarView.mode === 'compact' }\"\n              data-view=\"compact\"\n              :aria-pressed=\"$store.buscarView.mode === 'compact' ? 'true' : 'false'\"\n              @click=\"$store.buscarView.mode = 'compact'\">\n        <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/></svg> Compact\n      </button>\n    </div>\n  </div>\n\n  \n  \n  <div id=\"search-image-panel\"\n       class=\"search-image-panel\"\n       x-show=\"mode === 'image'\"\n       x-cloak\n       x-data=\"{\n         filename: '',\n         preview: '',\n         dragging: false,\n         \n         clearUploadError() {\n           const slot = document.getElementById('image-upload-error');\n           if (slot) { slot.textContent = ''; slot.classList.remove('is-error'); }\n           const input = this.$refs.imageInput;\n           if (input) input.setAttribute('aria-invalid', 'false');\n         },\n         setFile(file) {\n           if (!file) return;\n           this.clearUploadError();\n           this.filename = file.name;\n           if (this.preview) URL.revokeObjectURL(this.preview);\n           this.preview = URL.createObjectURL(file);\n         },\n         onPick(e) { this.setFile(e.target.files && e.target.files[0]); },\n         onDrop(e) {\n           \n           const dt = e.dataTransfer;\n           if (!dt || !dt.files || !dt.files.length) return;\n           const input = this.$refs.imageInput;\n           input.files = dt.files;\n           this.setFile(dt.files[0]);\n           input.dispatchEvent(new Event('change', { bubbles: true }));\n         }\n       }\">\n    <form hx-post=\"/api/search/image\"\n          hx-encoding=\"multipart/form-data\"\n          hx-trigger=\"change from:#image-input\"\n          hx-target=\"#search-results\"\n          hx-indicator=\"#search-skeleton\">\n      \n      <label class=\"image-dropzone\"\n             for=\"image-input\"\n             :class=\"{ 'is-dragging': dragging, 'has-file': filename, 'is-compact': searched && hits > 0 }\"\n             @dragover.prevent=\"dragging = true\"\n             @dragenter.prevent=\"dragging = true\"\n             @dragleave.prevent=\"dragging = false\"\n             @drop.prevent=\"dragging = false; onDrop($event)\">\n        <template x-if=\"!filename\">\n          <span class=\"dz-empty\">\n            <span class=\"dz-icon\" aria-hidden=\"true\"><svg width=\"26\" height=\"26\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" widt