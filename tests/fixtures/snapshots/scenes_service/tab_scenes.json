"\n\n\n<div class=\"tab-panel\">\n\n\n\n<section class=\"c-cp\"\n         x-data=\"{\n           refreshScenes() {\n             this.$nextTick(() => {\n               if (window.htmx) {\n                 window.htmx.trigger('#scenes-toolrow', 'refresh');\n               }\n             });\n           }\n         }\"\n         :class=\"{\n           'view-density-comfortable': $store.cenasAppearance.density === 'comfortable',\n           'view-density-compact':     $store.cenasAppearance.density === 'compact',\n           'hide-timecode':  !$store.cenasFields.timecode,\n           'hide-pin-count': !$store.cenasFields.pin_count,\n           'hide-version':   !$store.cenasFields.version,\n           'hide-sub':       !$store.cenasFields.sub,\n           'hide-tipo':      !$store.cenasFields.tipo,\n         }\">\n\n  \n  <div id=\"scenes-toolrow\"\n       class=\"toolrow\"\n       hx-get=\"/api/scenes\"\n       hx-trigger=\"refresh\"\n       hx-target=\"#scenes-grid\"\n       hx-swap=\"innerHTML\"\n       hx-indicator=\"#scenes-skeleton\"\n       hx-include=\"#scenes-toolrow\">\n\n    \n    <div class=\"filter-wrap\"\n         x-data=\"{ open: false }\"\n         @click.outside=\"open = false\"\n         @keydown.escape.window=\"open = false\">\n      <button type=\"button\"\n              class=\"tool\"\n              :class=\"{ 'tool--active': open || $store.cenasAppearance.density !== 'comfortable' }\"\n              :aria-expanded=\"open ? 'true' : 'false'\"\n              aria-haspopup=\"true\"\n              @click=\"open = !open\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"3\" width=\"7\" height=\"7\"/><rect x=\"3\" y=\"14\" width=\"7\" height=\"7\"/><rect x=\"14\" y=\"14\" width=\"7\" height=\"7\"/></svg></span>\n        Appearance\n      </button>\n\n      <div class=\"scenes-filter-popover\"\n           role=\"dialog\"\n           :aria-hidden=\"open ? 'false' : 'true'\"\n           x-show=\"open\"\n           x-cloak\n           x-transition.opacity.duration.120ms>\n        <header class=\"scenes-filter-popover__head\">\n          <span class=\"scenes-filter-popover__title\">Card density</span>\n        </header>\n        <div class=\"scenes-prefs-rows\">\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"density\"\n                   value=\"comfortable\"\n                   x-model=\"$store.cenasAppearance.density\">\n            <span>Comfortable</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"density\"\n                   value=\"compact\"\n                   x-model=\"$store.cenasAppearance.density\">\n            <span>Compact</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"filter-wrap\"\n         x-data=\"{ open: false }\"\n         @click.outside=\"open = false\"\n         @keydown.escape.window=\"open = false\">\n      <button type=\"button\"\n              class=\"tool\"\n              :class=\"{ 'tool--active': open || Object.values($store.cenasFields).some(v => !v) }\"\n              :aria-expanded=\"open ? 'true' : 'false'\"\n              aria-haspopup=\"true\"\n              @click=\"open = !open\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M12 2l3 7 7 .5-5.5 4.5 2 7L12 17l-6.5 4 2-7L2 9.5 9 9z\"/></svg></span>\n        Fields\n        <span class=\"pip\"\n              x-show=\"Object.values($store.cenasFields).some(v => !v)\"\n              x-text=\"Object.values($store.cenasFields).filter(v => !v).length\"\n              x-cloak></span>\n      </button>\n\n      <div class=\"scenes-filter-popover\"\n           role=\"dialog\"\n           :aria-hidden=\"open ? 'false' : 'true'\"\n           x-show=\"open\"\n           x-cloak\n           x-transition.opacity.duration.120ms>\n        <header class=\"scenes-filter-popover__head\">\n          <span class=\"scenes-filter-popover__title\">Visible fields</span>\n          <button type=\"button\"\n                  class=\"scenes-filter-popover__clear\"\n                  x-show=\"Object.values($store.cenasFields).some(v => !v)\"\n                  @click=\"\n                    $store.cenasFields.timecode = true;\n                    $store.cenasFields.pin_count = true;\n                    $store.cenasFields.version = true;\n                    $store.cenasFields.sub = true;\n                    $store.cenasFields.tipo = true;\n                  \">\n            Reset\n          </button>\n        </header>\n        <div class=\"scenes-prefs-rows\">\n          <label class=\"scenes-prefs-row\">\n            <input type=\"checkbox\" x-model=\"$store.cenasFields.timecode\">\n            <span>Timecode</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"checkbox\" x-model=\"$store.cenasFields.pin_count\">\n            <span>Pin count</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"checkbox\" x-model=\"$store.cenasFields.version\">\n            <span>Version</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"checkbox\" x-model=\"$store.cenasFields.sub\">\n            <span>Director · year</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"checkbox\" x-model=\"$store.cenasFields.tipo\">\n            <span>Type pill</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"filter-wrap\"\n         x-data=\"{ open: false, count: 0 }\"\n         @click.outside=\"open = false\"\n         @keydown.escape.window=\"open = false\">\n      <button type=\"button\"\n              class=\"tool\"\n              :class=\"{ 'tool--active': open || count > 0 }\"\n              :aria-expanded=\"open ? 'true' : 'false'\"\n              aria-haspopup=\"true\"\n              @click=\"open = !open\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><polygon points=\"22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3\"/></svg></span>\n        Filters<span class=\"pip\" x-show=\"count > 0\" x-text=\"count\" x-cloak></span>\n      </button>\n\n      <div class=\"scenes-filter-popover\"\n           role=\"dialog\"\n           :aria-hidden=\"open ? 'false' : 'true'\"\n           x-show=\"open\"\n           x-cloak\n           x-transition.opacity.duration.120ms>\n        <header class=\"scenes-filter-popover__head\">\n          <span class=\"scenes-filter-popover__title\">Filter by tag</span>\n          <button type=\"button\"\n                  class=\"scenes-filter-popover__clear\"\n                  x-show=\"count > 0\"\n                  @click=\"\n                    $refs.pills.querySelectorAll('input[name=tags]').forEach(i => i.checked = false);\n                    count = 0;\n                    window.htmx && window.htmx.trigger($refs.pills, 'refresh');\n                  \">\n            Clear\n          </button>\n        </header>\n        \n        <div x-ref=\"pills\"\n             id=\"scenes-filter-pills\"\n             class=\"tag-filter scenes-filter-popover__pills\"\n             hx-get=\"/api/scenes\"\n             hx-trigger=\"change from:input, refresh\"\n             hx-target=\"#scenes-grid\"\n             hx-swap=\"innerHTML\"\n             hx-include=\"#scenes-toolrow\"\n             @change=\"count = $el.querySelectorAll('input[name=tags]:checked').length\">\n          \n          <label class=\"tag-pill\">\n            <input type=\"checkbox\" name=\"tags\" value=\"dia\">dia\n          </label>\n          \n          <label class=\"tag-pill\">\n            <input type=\"checkbox\" name=\"tags\" value=\"exterior\">exterior\n          </label>\n          \n          <label class=\"tag-pill\">\n            <input type=\"checkbox\" name=\"tags\" value=\"manual-only\">manual-only\n          </label>\n          \n          <label class=\"tag-pill\">\n            <input type=\"checkbox\" name=\"tags\" value=\"noite\">noite\n          </label>\n          \n        </div>\n        \n      </div>\n    </div>\n\n    \n    <div class=\"filter-wrap\"\n         x-data=\"{ open: false }\"\n         @click.outside=\"open = false\"\n         @keydown.escape.window=\"open = false\">\n      <button type=\"button\"\n              class=\"tool\"\n              :class=\"{ 'tool--active': open || $store.cenasGroup.by !== 'film' }\"\n              :aria-expanded=\"open ? 'true' : 'false'\"\n              aria-haspopup=\"true\"\n              @click=\"open = !open\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"6\" rx=\"1\"/><rect x=\"3\" y=\"13\" width=\"18\" height=\"6\" rx=\"1\"/></svg></span>\n        Grouped by\n        <span class=\"v\"\n              x-text=\"({film: 'Film',\n                       tipo: 'Type',\n                       none: 'None'})[$store.cenasGroup.by]\">\n          Film\n        </span>\n      </button>\n      <div class=\"scenes-filter-popover\"\n           role=\"dialog\"\n           :aria-hidden=\"open ? 'false' : 'true'\"\n           x-show=\"open\"\n           x-cloak\n           x-transition.opacity.duration.120ms\n           id=\"scenes-group-popover\">\n        <header class=\"scenes-filter-popover__head\">\n          <span class=\"scenes-filter-popover__title\">Group scenes by</span>\n        </header>\n        <div class=\"scenes-prefs-rows\" @change=\"refreshScenes()\">\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"group_choice\" value=\"film\"\n                   x-model=\"$store.cenasGroup.by\">\n            <span>Film</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"group_choice\" value=\"tipo\"\n                   x-model=\"$store.cenasGroup.by\">\n            <span>Type</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"group_choice\" value=\"none\"\n                   x-model=\"$store.cenasGroup.by\">\n            <span>None (flat)</span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    <span class=\"div\" aria-hidden=\"true\"></span>\n\n    \n    <div class=\"filter-wrap\"\n         x-data=\"{ open: false }\"\n         @click.outside=\"open = false\"\n         @keydown.escape.window=\"open = false\">\n      <button type=\"button\"\n              class=\"tool\"\n              :class=\"{ 'tool--active': open || $store.cenasSort.by !== 'timecode' }\"\n              :aria-expanded=\"open ? 'true' : 'false'\"\n              aria-haspopup=\"true\"\n              @click=\"open = !open\">\n        <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M3 6h18M6 12h12M10 18h4\"/></svg></span>\n        Sorted by\n        <span class=\"v\"\n              x-text=\"({timecode: 'Timecode',\n                       duration: 'Duration',\n                       pins: 'Pin count'})[$store.cenasSort.by]\">\n          Timecode\n        </span>\n      </button>\n      <div class=\"scenes-filter-popover\"\n           role=\"dialog\"\n           :aria-hidden=\"open ? 'false' : 'true'\"\n           x-show=\"open\"\n           x-cloak\n           x-transition.opacity.duration.120ms\n           id=\"scenes-sort-popover\">\n        <header class=\"scenes-filter-popover__head\">\n          <span class=\"scenes-filter-popover__title\">Sort scenes by</span>\n        </header>\n        <div class=\"scenes-prefs-rows\" @change=\"refreshScenes()\">\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"sort_choice\" value=\"timecode\"\n                   x-model=\"$store.cenasSort.by\">\n            <span>Timecode</span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"sort_choice\" value=\"duration\"\n                   x-model=\"$store.cenasSort.by\">\n            <span>Duration <span class=\"scenes-prefs-row__hint\">longest first</span></span>\n          </label>\n          <label class=\"scenes-prefs-row\">\n            <input type=\"radio\" name=\"sort_choice\" value=\"pins\"\n                   x-model=\"$store.cenasSort.by\">\n            <span>Pin count <span class=\"scenes-prefs-row__hint\">most pinned first</span></span>\n          </label>\n        </div>\n      </div>\n    </div>\n\n    \n    <input type=\"hidden\" name=\"group\" :value=\"$store.cenasGroup.by\">\n    <input type=\"hidden\" name=\"sort\" :value=\"$store.cenasSort.by\">\n    \n\n    <span class=\"grow\" aria-hidden=\"true\"></span>\n    \n    <form class=\"find\"\n          hx-get=\"/api/scenes\"\n          hx-trigger=\"keyup changed delay:200ms, search\"\n          hx-target=\"#scenes-grid\"\n          hx-swap=\"innerHTML\"\n          hx-indicator=\"#scenes-skeleton\"\n          hx-include=\"#scenes-toolrow\">\n      <span class=\"ico\"><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><circle cx=\"11\" cy=\"11\" r=\"7\"/><path d=\"M21 21l-4.3-4.3\"/></svg></span>\n      \n      \n      <input type=\"search\" name=\"q\" placeholder=\"Search…\" value=\"\">\n    </form>\n  </div>\n\n  \n  <div class=\"scroll\">\n    <div class=\"countrow\">\n      <span class=\"chev\" aria-hidden=\"true\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><polyline points=\"6 9 12 15 18 9\"/></svg></span>\n      <span class=\"v\">2</span>\n      <span class=\"lab\">scenes</span>\n      <span class=\"div\" aria-hidden=\"true\"></span>\n      <span class=\"v\">1</span>\n      <span class=\"lab\">films</span>\n      <span class=\"div\" aria-hidden=\"true\"></span>\n      <span class=\"v\">2m</span>\n      <span class=\"lab\">runtime</span>\n      <span class=\"div\" aria-hidden=\"true\"></span>\n      <span class=\"v\">—</span>\n      <span class=\"lab\">keyframes</span>\n    </div>\n\n    \n    <div id=\"scenes-grid\" class=\"grid\">\n      \n\n\n\n  \n    \n    <div class=\"group\">\n      <span class=\"chev\" aria-hidden=\"true\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><polyline points=\"6 9 12 15 18 9\"/></svg></span>\n      <span class=\"dot\" style=\"background: var(--c-accent);\" aria-hidden=\"true\"></span>\n      <span class=\"name\">Default Film</span>\n      \n      <span class=\"ct\">2 / 2</span>\n      \n      <span class=\"meta\"><span>runtime 2m</span></span>\n      \n    </div>\n    \n    \n      \n      \n      \n      \n      <article class=\"scenecard\"\n               data-scene-id=\"351\"\n               hx-get=\"/api/scenes/351/inspector?film=default&tab=properties&kind=cenas\"\n               hx-target=\"#right-pane\"\n               hx-swap=\"innerHTML\"\n               hx-indicator=\"#inspector-skeleton\"\n               hx-trigger=\"click\">\n        <button type=\"button\" class=\"check\" title=\"Select\" aria-label=\"Select\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><polyline points=\"20 6 9 17 4 12\"/></svg></button>\n        <div class=\"kf\" role=\"img\" aria-label=\"Keyframe\">\n          \n          <span class=\"br\">00:01:23</span>\n          \n        </div>\n        <div class=\"body\">\n          \n          <h2 class=\"name fx-truncate\">scene 351</h2>\n          <div class=\"sub\">\n            <span class=\"dot-f\" style=\"background: var(--c-accent);\" aria-hidden=\"true\"></span>\n            <span>Default Film</span>\n            \n          </div>\n          <div class=\"tipo\">\n            <span class=\"lab\">TYPE</span>\n            <span class=\"pill tipo-pill--exterior\">Exterior</span>\n          </div>\n        </div>\n      </article>\n    \n      \n      \n      \n      \n      <article class=\"scenecard\"\n               data-scene-id=\"352\"\n               hx-get=\"/api/scenes/352/inspector?film=default&tab=properties&kind=cenas\"\n               hx-target=\"#right-pane\"\n               hx-swap=\"innerHTML\"\n               hx-indicator=\"#inspector-skeleton\"\n               hx-trigger=\"click\">\n        <button type=\"button\" class=\"check\" title=\"Select\" aria-label=\"Select\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><polyline points=\"20 6 9 17 4 12\"/></svg></button>\n        <div class=\"kf\" role=\"img\" aria-label=\"Keyframe\">\n          \n          <span class=\"br\">00:02:00</span>\n          \n        </div>\n        <div class=\"body\">\n          \n          <h2 class=\"name fx-truncate\">scene 352</h2>\n          <div class=\"sub\">\n            <span class=\"dot-f\" style=\"background: var(--c-accent);\" aria-hidden=\"true\"></span>\n            <span>Default Film</span>\n            \n          </div>\n          <div class=\"tipo\">\n            <span class=\"lab\">TYPE</span>\n            <span class=\"pill tipo-pill--exterior\">Exterior</span>\n          </div>\n        </div>\n      </article>\n    \n  \n\n    </div>\n    \n    \n<div id=\"scenes-skeleton\" class=\"skeleton-grid htmx-indicator\" aria-hidden=\"true\">\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n  <div class=\"skeleton-card\">\n    <div class=\"skeleton skeleton--kf\"></div>\n    <div class=\"sk-body\">\n      <div class=\"skeleton skeleton--line lg\"></div>\n      <div class=\"skeleton skeleton--line md\"></div>\n      <div class=\"sk-tags\">\n        <div class=\"skeleton skeleton--pill\"></div>\n        <div class=\"skeleton skeleton--pill\"></div>\n      </div>\n    </div>\n  </div>\n  \n</div>\n\n  </div>\n\n</section>\n\n\n\n\n<div class=\"rp-slot\">\n  <aside id=\"right-pane\">\n    <section class=\"c-rp\">\n      <div class=\"head\">\n        <div class=\"l\">\n          <span>Scene</span>\n        </div>\n      </div>\n      \n      <div class=\"inner inner--empty\">\n        <div class=\"fx-empty\">\n          <span class=\"glyph\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><circle cx=\"8.5\" cy=\"8.5\" r=\"1.5\"/><polyline points=\"21 15 16 10 5 21\"/></svg></span>\n          <p class=\"ttl\">No scene selected</p>\n          <p class=\"sub\">Select a scene in the grid to inspect its keyframe, tags, and description.</p>\n        </div>\n      </div>\n    </section>\n  </aside>\n  \n  \n<div id=\"inspector-skeleton\" class=\"skeleton-inspector htmx-indicator\" aria-hidden=\"true\">\n  <div class=\"skeleton skeleton--kf-wide\"></div>\n  <div class=\"skeleton skeleton--line lg\"></div>\n  <div class=\"skeleton skeleton--line sm\"></div>\n  <div class=\"sk-props\">\n    <div class=\"skeleton skeleton--line md\"></div>\n    <div class=\"skeleton skeleton--line md\"></div>\n    <div class=\"skeleton skeleton--line sm\"></div>\n    <div class=\"skeleton skeleton--line md\"></div>\n  </div>\n</div>\n\n</div>\n\n</div>"
