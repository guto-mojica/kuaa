"\n<div class=\"tab-panel\">\n<section class=\"p-cp\">\n\n  <header class=\"p-top\">\n    <div class=\"row1\">\n      <h1>\n        <span class=\"ic\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 12a9 9 0 1 1-6.2-8.5\"/></svg></span>\n        Processing\n        \n      </h1><div class=\"p-add-film\" x-data=\"{ open: false }\">\n        <button type=\"button\"\n                class=\"fx-btn secondary\"\n                @click=\"open = !open\"\n                :aria-expanded=\"open\">\n          <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg> Add film…\n        </button>\n        <form x-show=\"open\"\n              x-cloak\n              class=\"p-add-film__form\"\n              hx-post=\"/api/library/add\"\n              hx-swap=\"none\">\n          <input type=\"hidden\" name=\"source\" value=\"processing\">\n          <input class=\"filter-input\"\n                 type=\"text\"\n                 name=\"video_path\"\n                 placeholder=\"Absolute path to video file\"\n                 required>\n          <input class=\"filter-input\"\n                 type=\"text\"\n                 name=\"title\"\n                 placeholder=\"Title (optional)\">\n          <div style=\"display:flex; gap:8px; margin-top:6px;\">\n            <button type=\"submit\" class=\"fx-btn primary\">Register</button>\n            <button type=\"button\" class=\"fx-btn secondary\" @click=\"open = false\">Cancel</button>\n          </div>\n        </form>\n      </div>\n\n      <div class=\"acts\"><form class=\"pipeline-launch-bar\"\n              hx-post=\"/api/pipeline/enqueue\"\n              hx-target=\"closest .tab-panel\"\n              hx-swap=\"outerHTML\"\n              hx-indicator=\"#start-spinner\"\n              style=\"display:flex; align-items:center; gap:10px;\">\n\n          \n            <span class=\"text-muted\" style=\"font-size:0.8125rem\">No video files found in the raw directory.</span>\n          <div class=\"pipeline-steps-check\">\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"frame_extraction\" checked>\n                Frame extraction\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"scene_detection\" checked>\n                Scene detection\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"visual_analysis\" checked>\n                Visual analysis\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"embeddings\" checked>\n                Embeddings\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"llm_description\" checked>\n                LLM descriptions\n              </label>\n            \n          </div>\n\n          <button type=\"submit\" class=\"fx-btn primary\" disabled>\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\" focusable=\"false\"><polygon points=\"6 4 20 12 6 20\"/></svg> Start processing\n          </button>\n          <span id=\"start-spinner\" class=\"htmx-indicator text-muted\" style=\"font-size:0.75rem\">\n            Starting…\n          </span>\n        </form><form class=\"pipeline-launch-bar\"\n              hx-post=\"/api/pipeline/enqueue\"\n              hx-target=\"closest .tab-panel\"\n              hx-swap=\"outerHTML\"\n              hx-indicator=\"#queue-spinner\"\n              style=\"display:flex; align-items:center; gap:10px;\">\n          \n          <div class=\"pipeline-steps-check\" style=\"display:none;\">\n            \n              <input type=\"hidden\" name=\"steps\" value=\"frame_extraction\">\n            \n              <input type=\"hidden\" name=\"steps\" value=\"scene_detection\">\n            \n              <input type=\"hidden\" name=\"steps\" value=\"visual_analysis\">\n            \n              <input type=\"hidden\" name=\"steps\" value=\"embeddings\">\n            \n              <input type=\"hidden\" name=\"steps\" value=\"llm_description\">\n            \n          </div>\n          <button type=\"submit\" class=\"fx-btn secondary\" disabled>\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg> + Queue\n          </button>\n          <span id=\"queue-spinner\" class=\"htmx-indicator text-muted\" style=\"font-size:0.75rem\">\n            Queuing…\n          </span>\n        </form>\n      </div>\n    </div>\n  </header><div id=\"active-jobs\" style=\"padding: 0 24px;\">\n    <div id=\"processing-job\">\n      \n        <p class=\"text-muted\" style=\"font-size:0.8125rem; padding: 14px 0;\">No active jobs.</p>\n      \n    </div>\n  </div>\n\n  <div class=\"p-body\"><div class=\"p-log\" id=\"proc-log\"\n         >\n      <div class=\"head\">\n        <div class=\"l\">\n          <span class=\"dot\"></span>\n          <span>Log · SSE</span>\n        </div>\n        <div class=\"r\">\n          <button type=\"button\"\n                  class=\"fx-icbtn sm\"\n                  title=\"Download log\"\n                  aria-label=\"Download log\"\n                  data-download-log><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"7 10 12 15 17 10\"/><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/></svg></button>\n          <label class=\"fx-mono\" style=\"font-size:11px; color: var(--c-muted); display:inline-flex; align-items:center; gap:4px;\">\n            <input type=\"checkbox\" data-autoscroll checked>\n            auto-scroll\n          </label>\n        </div>\n      </div><div class=\"lines\"\n           data-empty-text=\"Waiting for events…\"\n           ></div>\n    </div>\n\n    <aside class=\"p-side\">\n      <section class=\"p-stats\">\n  <h3>STATS</h3>\n  <div class=\"grid\">\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">frames</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">scenes</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">embeddings</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">descriptions</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v \">0</span>\n      <span class=\"k\">faces</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">objects</span>\n    </div>\n  </div>\n</section>\n      \n\n<section class=\"p-queue\" id=\"p-queue-section\">\n  <h3>\n    QUEUE\n    \n  </h3>\n  \n    <p class=\"fx-mono\" style=\"font-size: 11px; color: var(--c-muted);\">\n      No history yet.\n    </p>\n  \n</section>\n    </aside>\n  </div>\n\n</section><aside class=\"p-rp p-rp--empty\" id=\"right-pane\">\n  <div class=\"p-rp__empty\">\n      <span class=\"p-rp__empty-glyph\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 12a9 9 0 1 1-6.2-8.5\"/></svg></span>\n      <p class=\"p-rp__empty-text\">Step detail appears here while a film is processing.</p>\n    </div>\n  \n</aside>\n\n</div>"
