"\n<div class=\"tab-panel\">\n<section class=\"p-cp\">\n\n  <header class=\"p-top\">\n    <div class=\"row1\">\n      <h1>\n        <span class=\"ic\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 12a9 9 0 1 1-6.2-8.5\"/></svg></span>\n        Processing\n        \n      </h1><div class=\"p-add-film\">\n        <button class=\"add\" type=\"button\"\n                title=\"Add film\"\n                aria-label=\"Add film\"\n                hx-get=\"/api/library/add-form?source=processing\"\n                hx-target=\"#proc-add-film-zone\"\n                hx-swap=\"innerHTML\"><svg width=\"12\" height=\"12\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></button>\n        <div id=\"proc-add-film-zone\"></div>\n      </div>\n\n      <div class=\"acts\"><form class=\"pipeline-launch-bar\"\n              x-data=\"{\n                steps: {\n                  frame_extraction: true,\n                  scene_detection: true,\n                  visual_analysis: true,\n                  embeddings: true,\n                  llm_description: true\n                },\n                get allSteps() { return Object.values(this.steps).every(Boolean); },\n                set allSteps(v) { Object.keys(this.steps).forEach(k => { this.steps[k] = v; }); },\n                sdDetector: 'adaptive'\n              }\"\n              hx-post=\"/api/pipeline/start\"\n              hx-target=\"closest .tab-panel\"\n              hx-swap=\"outerHTML\"\n              hx-indicator=\"#start-spinner\"\n              style=\"display:flex; flex-wrap:wrap; align-items:center; gap:10px;\">\n\n          \n            <span class=\"text-muted\" style=\"font-size:0.8125rem\">No video files found in the raw directory.</span>\n          <div class=\"pipeline-steps-check\">\n            <label class=\"tag-pill\">\n              <input type=\"checkbox\"\n                     :checked=\"allSteps\"\n                     @change=\"allSteps = $event.target.checked\">\n              All steps\n            </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"frame_extraction\"\n                       x-model=\"steps['frame_extraction']\">\n                Frame extraction\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"scene_detection\"\n                       x-model=\"steps['scene_detection']\">\n                Scene detection\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"visual_analysis\"\n                       x-model=\"steps['visual_analysis']\">\n                Visual analysis\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"embeddings\"\n                       x-model=\"steps['embeddings']\">\n                Embeddings\n              </label>\n            \n              <label class=\"tag-pill\">\n                <input type=\"checkbox\" name=\"steps\" value=\"llm_description\"\n                       x-model=\"steps['llm_description']\">\n                LLM descriptions\n              </label>\n            \n          </div><div class=\"sd-params\" x-show=\"steps.scene_detection\" x-cloak\n               style=\"width:100%; display:flex; flex-wrap:wrap; align-items:flex-start; gap:8px; padding:8px 0 4px;\">\n\n            <div class=\"sd-warn\" style=\"width:100%; font-size:0.75rem; color:var(--c-warn,#b45309); background:var(--c-warn-bg,#fef3c7); border:1px solid var(--c-warn-border,#fde68a); border-radius:4px; padding:6px 10px;\">\n              Re-running scene detection will delete all downstream outputs (visual analysis, embeddings, LLM descriptions). Check all steps, or run them separately after.\n            </div>\n\n            <label class=\"sd-field\" style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Detector\n              <select name=\"sd_detector\" x-model=\"sdDetector\"\n                      style=\"font-size:0.8125rem;\">\n                <option value=\"adaptive\">adaptive</option>\n                <option value=\"content\">content</option>\n              </select>\n            </label>\n\n            <label class=\"sd-field\" x-show=\"sdDetector === 'adaptive'\"\n                   style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Adaptive threshold\n              <input type=\"number\" name=\"sd_adaptive_threshold\" step=\"0.1\" min=\"0.1\" max=\"100\"\n                     value=\"3.0\"\n                     style=\"width:6rem; font-size:0.8125rem;\">\n            </label>\n\n            <label class=\"sd-field\" x-show=\"sdDetector === 'content'\"\n                   style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Content threshold\n              <input type=\"number\" name=\"sd_content_threshold\" step=\"0.5\" min=\"1\" max=\"100\"\n                     value=\"27.0\"\n                     style=\"width:6rem; font-size:0.8125rem;\">\n            </label>\n\n            <label class=\"sd-field\" style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Min scene length\n              <input type=\"number\" name=\"sd_min_scene_len\" step=\"1\" min=\"1\"\n                     value=\"15\"\n                     style=\"width:5rem; font-size:0.8125rem;\">\n            </label>\n\n            <label class=\"sd-field\" style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Keyframes / scene\n              <select name=\"sd_keyframes_per_scene\"\n                      style=\"font-size:0.8125rem;\">\n                <option value=\"1\">1</option>\n                <option value=\"3\" selected>3</option>\n              </select>\n            </label>\n\n            <label class=\"sd-field\" style=\"display:flex; flex-direction:column; gap:2px; font-size:0.75rem; color:var(--c-muted);\">\n              Keyframe height\n              <input type=\"number\" name=\"sd_keyframe_height\" step=\"1\" min=\"120\"\n                     value=\"480\"\n                     style=\"width:5rem; font-size:0.8125rem;\">\n            </label>\n          </div>\n\n          <button type=\"submit\" class=\"fx-btn primary\" disabled>\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"currentColor\" aria-hidden=\"true\" focusable=\"false\"><polygon points=\"6 4 20 12 6 20\"/></svg> Start processing\n          </button>\n          <span id=\"start-spinner\" class=\"htmx-indicator text-muted\" style=\"font-size:0.75rem\">\n            Starting…\n          </span><button type=\"button\" class=\"fx-btn secondary\"\n                  disabled\n                  hx-post=\"/api/pipeline/enqueue\"\n                  hx-include=\"closest form\"\n                  hx-target=\"closest .tab-panel\"\n                  hx-swap=\"outerHTML\"\n                  hx-indicator=\"#queue-spinner\">\n            <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg> + Queue\n          </button>\n          <span id=\"queue-spinner\" class=\"htmx-indicator text-muted\" style=\"font-size:0.75rem\">\n            Queuing…\n          </span>\n        </form>\n      </div>\n    </div>\n  </header><div id=\"active-jobs\" style=\"padding: 0 24px;\">\n    <div id=\"processing-job\">\n      \n        <p class=\"text-muted\" style=\"font-size:0.8125rem; padding: 14px 0;\">No active jobs.</p>\n      \n    </div>\n  </div>\n\n  <div class=\"p-body\"><div class=\"p-log\" id=\"proc-log\"\n         >\n      <div class=\"head\">\n        <div class=\"l\">\n          <span class=\"dot\"></span>\n          <span>Log · SSE</span>\n        </div>\n        <div class=\"r\">\n          <button type=\"button\"\n                  class=\"fx-icbtn sm\"\n                  title=\"Download log\"\n                  aria-label=\"Download log\"\n                  data-download-log><svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4\"/><polyline points=\"7 10 12 15 17 10\"/><line x1=\"12\" y1=\"15\" x2=\"12\" y2=\"3\"/></svg></button>\n          <label class=\"fx-mono\" style=\"font-size:11px; color: var(--c-muted); display:inline-flex; align-items:center; gap:4px;\">\n            <input type=\"checkbox\" data-autoscroll checked>\n            auto-scroll\n          </label>\n        </div>\n      </div><div class=\"lines\"\n           data-empty-text=\"Waiting for events…\"\n           ></div>\n    </div>\n\n    <aside class=\"p-side\">\n      <section class=\"p-stats\">\n  <h3>STATS</h3>\n  <div class=\"grid\">\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">frames</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">scenes</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">embeddings</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">descriptions</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v \">0</span>\n      <span class=\"k\">faces</span>\n    </div>\n    <div class=\"stat\">\n      <span class=\"v\">0</span>\n      <span class=\"k\">objects</span>\n    </div>\n  </div>\n</section>\n      \n\n<section class=\"p-queue\" id=\"p-queue-section\">\n  <h3>\n    QUEUE\n    \n  </h3>\n  \n    <p class=\"fx-mono\" style=\"font-size: 11px; color: var(--c-muted);\">\n      No history yet.\n    </p>\n  \n</section>\n    </aside>\n  </div>\n\n</section><aside class=\"p-rp p-rp--empty\" id=\"right-pane\">\n  <div class=\"p-rp__empty\">\n      <span class=\"p-rp__empty-glyph\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.7\" stroke-linecap=\"round\" stroke-linejoin=\"round\" aria-hidden=\"true\" focusable=\"false\"><path d=\"M21 12a9 9 0 1 1-6.2-8.5\"/></svg></span>\n      <p class=\"p-rp__empty-text\">Step detail appears here while a film is processing.</p>\n    </div>\n  \n</aside>\n\n</div>"
